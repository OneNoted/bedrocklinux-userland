#!/bedrock/libexec/busybox sh
#
# systemd creates generated .mount units for entries in /proc/self/mountinfo.
# Bedrock's per-stratum API filesystem mirrors and implementation mounts
# should not be stopped like ordinary local filesystems during umount.target.

[ "${SYSTEMD_IN_INITRD:-0}" = "1" ] && exit 0
command -v systemd-escape >/dev/null 2>&1 || exit 0

out="${1:-}"
[ -n "${out}" ] || exit 0
[ -r /proc/self/mountinfo ] || exit 0

write_dropin() {
	path="${1}"
	dropin="${2}"
	description="${3}"

	unit="$(systemd-escape -p --suffix=mount "${path}")" || return
	write_dropin_for_unit "${unit}" "${dropin}" "${description}"
}

write_prefix_dropin() {
	path="${1}"
	dropin="${2}"
	description="${3}"

	unit="$(systemd-escape -p --suffix=mount "${path}")" || return
	write_dropin_for_unit "${unit%.mount}-.mount" "${dropin}" "${description}"
}

write_dropin_for_unit() {
	unit="${1}"
	dropin="${2}"
	description="${3}"
	dir="${out}/${unit}.d"

	mkdir -p "${dir}" || return
	{
		printf '%s\n' '# Generated by Bedrock Linux.'
		printf '# %s\n' "${description}"
		printf '%s\n' '[Unit]'
		printf '%s\n' 'DefaultDependencies=no'
	} >"${dir}/${dropin}"
}

write_api_dropin() {
	write_dropin \
		"${1}" \
		"50-bedrock-api-mount.conf" \
		"Bedrock API filesystem mirrors must not be stopped as ordinary local mounts."
}

write_api_prefix_dropin() {
	write_prefix_dropin \
		"${1}" \
		"50-bedrock-api-mount.conf" \
		"Bedrock API filesystem mirrors must not be stopped as ordinary local mounts."
}

write_implementation_dropin() {
	write_dropin \
		"${1}" \
		"50-bedrock-implementation-mount.conf" \
		"Bedrock implementation mounts must not be stopped as ordinary local mounts."
}

write_implementation_parent_dropin() {
	mount_point="${1}"

	case "${mount_point}" in
	/bedrock/strata/*) ;;
	*) return ;;
	esac

	relative="${mount_point#/bedrock/strata/}"
	stratum="${relative%%/*}"

	[ -n "${stratum}" ] || return
	write_implementation_dropin "/bedrock/strata/${stratum}/bedrock"
}

process_api_mount() {
	mount_point="${1}"

	case "${mount_point}" in
	/bedrock/strata/*/*) ;;
	*) return ;;
	esac

	relative="${mount_point#/bedrock/strata/}"
	stratum="${relative%%/*}"
	api_path="${relative#*/}"
	api_root="${api_path%%/*}"
	api_mirror_root="/bedrock/strata/${stratum}/${api_root}"

	[ -n "${stratum}" ] || return

	case "${api_root}" in
	dev | proc | run | sys) ;;
	*) return ;;
	esac

	write_api_dropin "${mount_point}"
	write_api_prefix_dropin "${api_mirror_root}"
	write_api_dropin "/bedrock"
	write_api_dropin "/bedrock/strata/${stratum}"
}

process_implementation_mount() {
	mount_point="${1}"
	fs_type="${2}"

	case "${mount_point}:${fs_type}" in
	/etc:fuse.etcfs | \
		/bedrock/cross:fuse.crossfs | \
		/bedrock/run:tmpfs | \
		/bedrock/strata/*/etc:fuse.etcfs)
		write_implementation_dropin "${mount_point}"
		;;
	/bedrock/strata/*/bedrock/cross:fuse.crossfs | \
		/bedrock/strata/*/bedrock/run:tmpfs)
		write_implementation_dropin "${mount_point}"
		write_implementation_parent_dropin "${mount_point}"
		;;
	esac

	case "${mount_point}" in
	/bedrock/strata/*)
		relative="${mount_point#/bedrock/strata/}"
		implementation_path="${relative#*/}"

		case "${implementation_path}" in
		bedrock)
			write_implementation_dropin "${mount_point}"
			;;
		bedrock/strata/bedrock)
			write_implementation_dropin "${mount_point}"
			write_implementation_parent_dropin "${mount_point}"
			;;
		esac
		;;
	esac
}

awk '{
	for (i=7; i<=NF; i++) {
		if ($i == "-") {
			print $5, $(i+1)
			next
		}
	}
}' /proc/self/mountinfo | while read -r mount_point fs_type; do
	process_api_mount "${mount_point}"
	process_implementation_mount "${mount_point}" "${fs_type}"
done
